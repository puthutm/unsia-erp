# ==============================
# UNSIA ERP - Environment Variables
# ==============================

# ==============================
# DATABASE
# ==============================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ==============================
# RABBITMQ
# ==============================
RABBITMQ_USER=unsia
RABBITMQ_PASSWORD=unsia
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672

# ==============================
# REDIS
# ==============================
REDIS_HOST=localhost
REDIS_PORT=6379

# ==============================
# CORE SERVICE (Port 8001)
# ==============================
CORE_SERVICE_PORT=8001
CORE_DATABASE_URL=postgres://postgres:postgres@tcp(localhost:5432)/core_db?charset=utf8mb4&parseTime=True&loc=local
JWT_SECRET=your-secret-key-here-change-in-production
RSA_PRIVATE_KEY_PATH=keys/private.pem
RSA_PUBLIC_KEY_PATH=keys/public.pem
JWKS_URL=http://localhost:8001/.well-known/jwks.json

# ==============================
# REFERENCE SERVICE (Port 8002)
# ==============================
REFERENCE_SERVICE_PORT=8002
REFERENCE_DATABASE_URL=postgres://postgres:postgres@tcp(localhost:5432)/reference_db?charset=utf8mb4&parseTime=True&loc=local
CORE_SERVICE_URL=http://localhost:8001

# ==============================
# PMB SERVICE (Port 8003)
# ==============================
PMB_SERVICE_PORT=8003
PMB_DATABASE_URL=postgres://postgres:postgres@tcp(localhost:5432)/pmb_db?charset=utf8mb4&parseTime=True&loc=local
REFERENCE_SERVICE_URL=http://localhost:8002

# ==============================
# ACADEMIC SERVICE (Port 8004)
# ==============================
ACADEMIC_SERVICE_PORT=8004
ACADEMIC_DATABASE_URL=postgres://postgres:postgres@tcp(localhost:5432)/academic_db?charset=utf8mb4&parseTime=True&loc=local
FINANCE_SERVICE_URL=http://localhost:8005

# ==============================
# FINANCE SERVICE (Port 8005)
# ==============================
FINANCE_SERVICE_PORT=8005
FINANCE_DATABASE_URL=postgres://postgres:postgres@tcp(localhost:5432)/finance_db?charset=utf8mb4&parseTime=True&loc=local
REFERENCE_SERVICE_URL=http://localhost:8002

# Payment Gateway (Midtrans)
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_ENVIRONMENT=sandbox

# ==============================
# LMS SERVICE (Port 8006)
# ==============================
LMS_SERVICE_PORT=8006
LMS_DATABASE_URL=postgres://postgres:postgres@tcp(localhost:5432)/lms_db?charset=utf8mb4&parseTime=True&loc=local
ACADEMIC_SERVICE_URL=http://localhost:8004

# ==============================
# ASSESSMENT SERVICE (Port 8007)
# ==============================
ASSESSMENT_SERVICE_PORT=8007
ASSESSMENT_DATABASE_URL=postgres://postgres:postgres@tcp(localhost:5432)/assessment_db?charset=utf8mb4&parseTime=True&loc=local
LMS_SERVICE_URL=http://localhost:8006

# ==============================
# HRIS SERVICE (Port 8008)
# ==============================
HRIS_SERVICE_PORT=8008
HRIS_DATABASE_URL=postgres://postgres:postgres@tcp(localhost:5432)/hris_db?charset=utf8mb4&parseTime=True&loc=local
FINANCE_SERVICE_URL=http://localhost:8005

# ==============================
# CRM SERVICE (Port 8009)
# ==============================
CRM_SERVICE_PORT=8009
CRM_DATABASE_URL=postgres://postgres:postgres@tcp(localhost:5432)/crm_db?charset=utf8mb4&parseTime=True&loc=local
REFERENCE_SERVICE_URL=http://localhost:8002

# ==============================
# PORTAL SERVICE (Port 8010)
# ==============================
PORTAL_SERVICE_PORT=8010
PORTAL_DATABASE_URL=postgres://postgres:postgres@tcp(localhost:5432)/portal_db?charset=utf8mb4&parseTime=True&loc=local

# ==============================
# FRONTEND (Port 3000)
# ==============================
NEXT_PUBLIC_API_CORE_URL=http://localhost:8001
NEXT_PUBLIC_API_REFERENCE_URL=http://localhost:8002
NEXT_PUBLIC_API_PMB_URL=http://localhost:8003
NEXT_PUBLIC_API_ACADEMIC_URL=http://localhost:8004
NEXT_PUBLIC_API_FINANCE_URL=http://localhost:8005
NEXT_PUBLIC_API_LMS_URL=http://localhost:8006
NEXT_PUBLIC_API_ASSESSMENT_URL=http://localhost:8007
NEXT_PUBLIC_API_HRIS_URL=http://localhost:8008
NEXT_PUBLIC_API_CRM_URL=http://localhost:8009
NEXT_PUBLIC_API_PORTAL_URL=http://localhost:8010
