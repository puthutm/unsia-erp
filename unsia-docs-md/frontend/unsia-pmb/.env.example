# PMB Frontend Environment Variables
# Copy this file to .env.local and fill in the values

# API Base URLs (Backend Services)
NEXT_PUBLIC_PMB_API=http://localhost:8003
NEXT_PUBLIC_REFERENCE_API=http://localhost:8002
NEXT_PUBLIC_CORE_API=http://localhost:8001
NEXT_PUBLIC_ACADEMIC_API=http://localhost:8004
NEXT_PUBLIC_FINANCE_API=http://localhost:8005

# Application Config
NEXT_PUBLIC_APP_NAME=UNSIA PMB
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_PORT=3000

# Feature Flags
NEXT_PUBLIC_ENABLE_DEBUG=false
NEXT_PUBLIC_ENABLE_ANALYTICS=true

# Storage (for development - use actual cloud in production)
NEXT_PUBLIC_STORAGE_BUCKET=unsia-pmb-dev
NEXT_PUBLIC_STORAGE_REGION=ap-southeast-1
